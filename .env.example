# Local Docker Compose settings.
# Copy this file to .env for local development if needed.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
JWT_SECRET=change-this-local-dev-secret
JWT_EXPIRES_IN_SECONDS=86400

SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host.neon.tech/your-db?sslmode=require
SPRING_DATASOURCE_USERNAME=your-neon-user
SPRING_DATASOURCE_PASSWORD=your-neon-password
