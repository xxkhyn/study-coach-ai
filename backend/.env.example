# Railway backend environment variables.
# Set these in Railway Variables. Do not commit real values.

PORT=8080

# Neon provides several connection string formats.
# Use the JDBC format for Spring Boot:
# jdbc:postgresql://<host>/<database>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://example.neon.tech/study_coach_ai?sslmode=require
SPRING_DATASOURCE_USERNAME=neon_user
SPRING_DATASOURCE_PASSWORD=neon_password

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=86400
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
